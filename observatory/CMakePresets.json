{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc-16",
        "CMAKE_CXX_COMPILER": "g++-16"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "OpenCV_DIR": "$env{OpenCV_DIR}"
      }
    },
    {
      "name": "debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OBSERVATORY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OBSERVATORY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "debug-cuda",
      "inherits": "debug",
      "cacheVariables": {
        "OBSERVATORY_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OBSERVATORY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-release",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OBSERVATORY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-debug-cuda",
      "inherits": "windows-debug",
      "cacheVariables": {
        "OBSERVATORY_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "windows-release-cuda",
      "inherits": "windows-release",
      "cacheVariables": {
        "OBSERVATORY_ENABLE_CUDA": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "debug-cuda", "configurePreset": "debug-cuda" },
    { "name": "windows-debug", "configurePreset": "windows-debug" },
    { "name": "windows-release", "configurePreset": "windows-release" },
    { "name": "windows-debug-cuda", "configurePreset": "windows-debug-cuda" },
    { "name": "windows-release-cuda", "configurePreset": "windows-release-cuda" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
